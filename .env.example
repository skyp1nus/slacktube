# ============================================================================
#  SlackTube — backend (.NET) configuration
#  Copy to .env (or export as real env vars). ASP.NET maps "__" to nested keys.
# ============================================================================

# ---- Database --------------------------------------------------------------
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=slacktube;Username=slacktube;Password=slacktube
ConnectionStrings__Redis=localhost:6379

# ---- Slack (OAuth v2 install) ----------------------------------------------
# Signing secret is env-only (OAuth doesn't return it). Client id/secret are from
# your Slack app's "Basic Information". Redirect URI must match the app config exactly.
Slack__SigningSecret=
Slack__ClientId=
Slack__ClientSecret=
Slack__RedirectUri=http://localhost:5080/slack/oauth/callback

# ---- Google OAuth (YouTube upload + Drive readonly) ------------------------
# OAuth clients (one per Google Cloud project) are now managed in the admin panel's
# "Projects" tab. These env values are an OPTIONAL seed: on first startup they become a
# "Default (env)" project and existing accounts are bound to it (backward compatible).
# Leave blank to manage all projects from the UI.
Google__ClientId=your-client-id.apps.googleusercontent.com
Google__ClientSecret=your-client-secret
# Global OAuth callback. EVERY project's OAuth client must register this EXACT redirect URI
# (it must match an Authorized redirect URI in each Google Cloud project's console):
Google__RedirectUri=http://localhost:5080/google/oauth/callback

# ---- Secret encryption -----------------------------------------------------
# Master passphrase used to protect refresh tokens / Slack secrets at rest.
# Min 32 chars. Changing it makes previously stored secrets undecryptable.
TokenEncryption__Key=CHANGE-ME-to-a-long-random-32+char-secret

# ---- Admin panel login (single admin, MVP) --------------------------------
Admin__Username=admin
Admin__Password=CHANGE-ME

# ---- App -------------------------------------------------------------------
# Public base URL of THIS backend (used to build the Google redirect + Slack links).
App__PublicBaseUrl=http://localhost:5080
# Web admin panel origin — OAuth callbacks bounce the browser back here.
App__AdminPanelUrl=http://localhost:3000
# Where Drive files are streamed before upload; cleaned up after every job.
App__TempDownloadDir=./tmp
# Per-project daily upload cap — videos.insert calls per PT day (Google default 100). The real upload gate.
App__YouTubeDailyUploadLimit=100
# Informational non-upload unit pool (list/search etc.); uploads do NOT draw from it.
App__YouTubeDailyQuotaUnits=10000

# ============================================================================
#  /web (Next.js) has its OWN .env.example — see web/.env.example
# ============================================================================
