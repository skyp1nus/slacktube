# ============================================================================
#  /opt/slacktube/.env  —  copy this file there, fill in, keep OFF git.
#  Consumed by deploy/docker-compose.prod.yml. ASP.NET maps "__" to nested keys.
# ============================================================================

# ---- GHCR image coordinates (lowercase). IMAGE_TAG is overwritten per-release
#      by the deploy workflow (commit SHA); "latest" is the manual fallback. -----
GH_REPO=skyp1nus/slacktube
IMAGE_TAG=latest

# ---- Public origin. The shared Caddy terminates TLS for this domain. ----------
#      Drives Google/Slack redirect URIs + the panel origin (see compose).
App__PublicBaseUrl=https://slacktube.danielhub.dev

# ---- Postgres (SHARED instance, database "slacktube", role "slacktube") --------
#      Host "postgres" is the shared stack's network alias on the "web" network.
#      Password must equal SLACKTUBE_DB_PASSWORD in /opt/shared/.env.
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=slacktube;Username=slacktube;Password=__SLACKTUBE_DB_PASSWORD__

# ---- Redis (SHARED instance) --------------------------------------------------
ConnectionStrings__Redis=redis:6379

# ---- Secret-at-rest master key (AES-256-GCM, >=32 chars) ----------------------
#      NEVER change after first deploy — rotating it makes every stored Google
#      refresh token / Slack secret undecryptable.  openssl rand -base64 48
TokenEncryption__Key=__CHANGE_ME__

# ---- Panel admin login + the shared key the Next.js BFF uses server-side -------
Admin__Username=admin
Admin__Password=__CHANGE_ME__
# X-Admin-Token guarding /api/admin/*. The frontend's BACKEND_ADMIN_TOKEN reuses it
# (wired in compose). Use a long random token.  openssl rand -hex 32
Admin__ApiKey=__CHANGE_ME__

# ---- Next.js panel session HMAC key (>=32 chars) ------------------------------
#      openssl rand -base64 48
SESSION_SECRET=__CHANGE_ME__

# ---- Google OAuth (YouTube upload + Drive readonly) ---------------------------
Google__ClientId=__CHANGE_ME__.apps.googleusercontent.com
Google__ClientSecret=__CHANGE_ME__

# ---- Slack app (signing secret is env-only; client id/secret from Basic Info) -
Slack__SigningSecret=__CHANGE_ME__
Slack__ClientId=__CHANGE_ME__
Slack__ClientSecret=__CHANGE_ME__

# ---- Optional tuning ----------------------------------------------------------
App__TransferChunkSizeMb=64
